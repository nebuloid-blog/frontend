	"packageManager": "yarn@3.2.1",
	"main": "",
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"storybook": "storybook dev -s public -p 6006",
		"build-storybook": "storybook build",
		"indent": "replace-in-files --string='  ' --replacement='\t'",
		"generate": "yarn generate:code && yarn generate:lint --fix; yarn generate:indent",
		"generate:indent": "yarn indent ./src/**/generated/**/*.ts",
		"generate:code": "echo generating... && graphql-codegen --config .codegenrc.json",
		"generate:lint": "echo linting... && eslint ./src/**/generated/**/*.ts --no-ignore --rule '@typescript-eslint/consistent-type-definitions: 0'"
	},
	"dependencies": {
		"@formspree/react": "^2.4.1",
		"@tanstack/react-query": "^4.29.7",
		"graphql": "^16.6.0",
		"graphql-request": "^6.0.0",
		"next": "^13.4.3",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-hook-form": "^7.43.9",
		"rehype": "^12.0.1",
		"rehype-parse": "^8.0.4",
		"rehype-react": "^7.2.0",
		"rehype-sanitize": "^5.0.1",
		"rehype-shift-heading": "^1.0.2"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^3.2.1",
		"@graphql-codegen/client-preset": "^1.1.3",
		"@storybook/addon-essentials": "^7.0.13",
		"@storybook/addon-interactions": "^7.0.13",
		"@storybook/addon-links": "^7.0.13",
		"@storybook/react": "^7.0.13",
		"@storybook/react-webpack5": "^7.0.13",
		"@storybook/testing-library": "^0.1.0",
		"@types/node": "^18.16.14",
		"@types/react": "^18.2.6",
		"@types/react-dom": "^18.2.4",
		"@typescript-eslint/eslint-plugin": "^5.59.7",
		"@typescript-eslint/parser": "^5.59.7",
		"eslint": "^8.41.0",
		"eslint-config-next": "^13.4.3",
		"eslint-config-tabbify-typescript": "^0.1.9",
		"eslint-plugin-import": "^2.27.5",
		"replace-in-files-cli": "^2.2.0",
		"sass": "^1.62.1",
		"storybook": "^7.0.13",
		"storybook-addon-next": "^1.8.0",
		"storybook-addon-swc": "^1.2.0",
		"typescript": "^5.0.4"
	}
